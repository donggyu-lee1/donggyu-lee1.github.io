---
import BaseLayout from "./BaseLayout.astro";
import { formatPostDate, type WritingEntry } from "../lib/writing";

interface Props {
  post: WritingEntry;
}

const { post } = Astro.props;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  pageType="article"
  pubDate={post.data.pubDate}
>
  <main id="top">
    <article class="section writing-post">
      <div class="shell writing-post-shell">
        <a class="writing-back-link" href="/writing/">&larr; All writing</a>
        <header class="writing-post-header">
          <time datetime={post.data.pubDate.toISOString()}>
            {formatPostDate(post.data.pubDate)}
          </time>
          <h1>{post.data.title}</h1>
          <p>{post.data.description}</p>
          {
            post.data.tags.length > 0 && (
              <div class="writing-tags" aria-label="Tags">
                {post.data.tags.map((tag) => <span>{tag}</span>)}
              </div>
            )
          }
        </header>
        <div class="writing-body prose">
          <slot />
        </div>
      </div>
    </article>
  </main>
</BaseLayout>
