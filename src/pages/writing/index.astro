---
import WritingCard from "../../components/WritingCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../../lib/writing";

const posts = await getPublishedPosts();
const description =
  "Notes and essays by Donggyu Lee on machine learning, economics, computational social science, and research.";
---

<BaseLayout title="Writing" description={description}>
  <main id="top">
    <section class="section writing-index">
      <div class="shell writing-index-shell">
        <header class="writing-index-header">
          <p class="writing-eyebrow">Writing</p>
          <h1>Notes and essays</h1>
          <p>{description}</p>
        </header>

        {
          posts.length > 0 ? (
            <div class="writing-list">
              {posts.map((post) => <WritingCard post={post} />)}
            </div>
          ) : (
            <div class="writing-empty-state">
              <h2>No posts yet</h2>
              <p>New writing will appear here.</p>
            </div>
          )
        }
      </div>
    </section>
  </main>
</BaseLayout>
