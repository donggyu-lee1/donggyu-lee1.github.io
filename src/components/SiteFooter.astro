---
import site from "../../data/site.json";

const currentYear = new Date().getUTCFullYear();
const resolveHref = (href: string) =>
  href.startsWith("./") ? `/${href.slice(2)}` : href;
---

<footer id="contact" class="site-footer">
  <div class="shell footer-grid">
    <div>
      <h2>{site.contact.heading}</h2>
      <p>{site.contact.name}</p>
      <p>{site.contact.role}</p>
      <p class="muted">{site.contact.email}</p>
    </div>
    <div class="footer-links">
      {
        site.contact.links.map((link) => (
          <a
            href={resolveHref(link.href)}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noopener" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
  <div class="shell footer-bottom">
    <span>&copy; {currentYear} Donggyu Lee</span>
    <span>{site.footer.note}</span>
  </div>
</footer>
